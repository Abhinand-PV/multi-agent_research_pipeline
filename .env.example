# ============================================================
# Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.
# ============================================================

# ── Required ────────────────────────────────────────────────

# Groq API Key — get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ────────────────────────────────────────────────

# Groq model to use for all agents.
# Options (fastest → best quality):
#   llama-3.1-8b-instant      (default — fast and free-tier friendly)
#   llama-3.3-70b-versatile   (higher quality, more latency)
#   llama3-70b-8192           (alternative 70B option)
GROQ_MODEL=llama-3.1-8b-instant

# Disable OpenAI Agents SDK tracing (recommended: keep at 1)
OPENAI_AGENTS_DISABLE_TRACING=1
